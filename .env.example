# --- Database (Neon / any Postgres) ---
# Get a free Postgres at https://neon.tech and paste the connection string here.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth (NextAuth v5) ---
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- AI lessons (optional, Phase 6) ---
# Without it, adaptive lessons fall back to a deterministic sequence.
ANTHROPIC_API_KEY=""
